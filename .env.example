# Solus Protocol Frontend

# REST API base URL — points to the Express backend
# All SWR data hooks fetch from this URL (agents, prices, leaderboard, proofs, logs)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# WebSocket URL — Socket.io connection for real-time pipeline events
# The frontend listens for live events (AGENT_THINKING, TX_CONFIRMED, etc.)
# to update pipeline steps, strategist lines, and policy checks in real-time
NEXT_PUBLIC_WS_URL=http://localhost:3001